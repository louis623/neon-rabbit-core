# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — use sk_test_ / whsec_test_ for development, sk_live_ / whsec_ for production
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs — create these in the Stripe Dashboard under Products
# Leave unset to disable that plan tier (checkout will return 400)
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_QUARTERLY=price_xxx
STRIPE_PRICE_ANNUAL=price_xxx

# App URL — used to build checkout success/cancel and portal return URLs
# Must match your actual deployment domain (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
